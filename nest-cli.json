{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": false,
    "builder": "swc",
    "typeCheck": false
  },
  "plugins": [
    {
      "name": "@nestjs/swagger",
      "options": {
        "classValidatorShim": true,
        "dtoFileNameSuffix": [".dto.ts"],
        "controllerFileNameSuffix": [".controller.ts"]
      }
    }
  ]
}
