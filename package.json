{
  "name": "permissions.api",
  "private": true,
  "version": "1.0.0",
  "description": "Repository for the permissions template API",
  "license": "MIT",
  "scripts": {
    "build": "nest build && tsc-alias -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "pnpm run build && node dist/src/main.js",
    "start:dev": "concurrently -k -n nest,alias \"nest start --watch -b swc\" \"wait-on dist/src/main.js && tsc-alias -p tsconfig.json && tsc-alias -p tsconfig.json -w\"",
    "start:debug": "concurrently -k -n nest,alias \"nest start --debug --watch -b swc\" \"wait-on dist/src/main.js && tsc-alias -p tsconfig.json && tsc-alias -p tsconfig.json -w\"",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:generate": "pnpm exec ts-node -r tsconfig-paths/register scripts/generate-migration.ts",
    "migration:run": "pnpm exec ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/infra/database/typeorm/data-source.ts",
    "migration:revert": "pnpm exec ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d src/infra/database/typeorm/data-source.ts",
    "schema:drop": "pnpm exec ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js schema:drop -d src/infra/database/typeorm/data-source.ts"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@keyv/redis": "5.1.6",
    "@nestjs/cache-manager": "3.1.0",
    "@nestjs/common": "11.0.17",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.0.1",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/platform-express": "11.1.11",
    "@nestjs/swagger": "8.1.0",
    "@nestjs/throttler": "6.4.0",
    "@nestjs/typeorm": "10.0.2",
    "cache-manager": "7.2.8",
    "keyv": "^5.6.0",
    "otplib": "12.0.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "pg": "8.16.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "typeorm": "0.3.20",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.18.0",
    "@nestjs/cli": "11.0.0",
    "@nestjs/schematics": "11.0.0",
    "@nestjs/testing": "11.0.1",
    "@swc/cli": "0.6.0",
    "@swc/core": "1.10.8",
    "@types/express": "5.0.0",
    "@types/jest": "29.5.14",
    "@types/node": "22.10.7",
    "@types/supertest": "6.0.2",
    "concurrently": "9.2.1",
    "eslint": "9.18.0",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-prettier": "5.2.3",
    "globals": "15.14.0",
    "jest": "29.7.0",
    "prettier": "3.4.2",
    "source-map-support": "0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.2",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.17",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0",
    "wait-on": "9.0.10"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@application/(.*)$": "<rootDir>/application/$1",
      "^@config/(.*)$": "<rootDir>/config/$1",
      "^@infra/(.*)$": "<rootDir>/infra/$1",
      "^@modules/(.*)$": "<rootDir>/modules/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@swc/core"
    ]
  }
}
