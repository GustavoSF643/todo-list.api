# APP
PORT=5000
NODE_ENV=development
APP_NAME=Todo Lists API — Auth & RBAC

# AUTH
JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET
JWT_EXPIRES_IN=3600

# DATABASE
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DATABASE=permissions
POSTGRES_SSL=false

# REDIS (cache via CacheInfraModule). Leave empty for in-memory cache.
REDIS_URL=redis://localhost:6379